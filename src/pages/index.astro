---
import AppLayout from "../layouts/AppLayout.astro";
import {
  AlertTriangle,
  Bell,
  Building2,
  CalendarDays,
  CircleParking,
  ClipboardList,
  KeyRound,
  ListChecks,
  MessageSquareWarning,
  Newspaper,
  Recycle,
  Wrench,
} from "@lucide/astro";
const base = import.meta.env.BASE_URL;
---

<AppLayout title="ホーム" page="home">
  <header class="page-head">
    <div>
      <p class="eyebrow">Dashboard</p>
      <h1>今日の管理状況</h1>
      <p class="lead">未処理の申請、期限が近い事項、最近の連絡を一つの画面で確認できます。</p>
    </div>
  </header>

  <section class="grid cols-3" aria-label="主要指標">
    <div class="panel metric">
      <span>承認待ち</span>
      <strong data-metric="pending-bookings">0</strong>
    </div>
    <div class="panel metric">
      <span>未読通知</span>
      <strong data-metric="unread-notices">0</strong>
    </div>
    <div class="panel metric">
      <span>今月の行事</span>
      <strong data-metric="month-events">0</strong>
    </div>
  </section>

  <section class="grid cols-2 dashboard-priority" aria-label="よく使う操作">
    <div class="panel">
      <div class="list-row">
        <h2><ListChecks size={18} aria-hidden="true" /> よく使う操作</h2>
      </div>
      <div class="quick-actions" data-quick-actions>
        <a class="quick-action" href={`${base}rooms/`}>
          <Building2 size={18} aria-hidden="true" />
          <span>会議室予約</span>
        </a>
        <a class="quick-action" href={`${base}maintenance/`}>
          <Wrench size={18} aria-hidden="true" />
          <span>修繕依頼</span>
        </a>
        <a class="quick-action" href={`${base}requests/`}>
          <MessageSquareWarning size={18} aria-hidden="true" />
          <span>相談送信</span>
        </a>
        <a class="quick-action" href={`${base}circulars/`}>
          <Newspaper size={18} aria-hidden="true" />
          <span>回覧確認</span>
        </a>
        <a class="quick-action" href={`${base}waste/`}>
          <Recycle size={18} aria-hidden="true" />
          <span>粗大ごみ申請</span>
        </a>
        <a class="quick-action" href={`${base}parking/`}>
          <CircleParking size={18} aria-hidden="true" />
          <span>駐車申請</span>
        </a>
        <a class="quick-action" href={`${base}lending/`}>
          <KeyRound size={18} aria-hidden="true" />
          <span>鍵・備品貸出</span>
        </a>
      </div>
    </div>

    <div class="panel" data-my-work>
      <div class="list-row">
        <h2><ClipboardList size={18} aria-hidden="true" /> 自分の未完了</h2>
        <strong class="amount" data-metric="home-actions">0</strong>
      </div>
      <p class="meta">未確認、未処理、期限が近い事項を下の「今日の対応」にまとめています。</p>
      <div class="work-summary">
        <a href={`${base}circulars/`}>回覧確認</a>
        <a href={`${base}duties/`}>当番確認</a>
        <a href={`${base}surveys/`}>意見回答</a>
      </div>
    </div>
  </section>

  <section class="grid cols-2" style="margin-top: 16px;">
    <div class="panel">
      <div class="list-row">
        <h2><ListChecks size={18} aria-hidden="true" /> 今日の対応</h2>
      </div>
      <div class="list compact-list" data-home-actions></div>
    </div>

    <div class="panel">
      <div class="list-row">
        <h2><AlertTriangle size={18} aria-hidden="true" /> 期限・注意</h2>
        <strong class="amount" data-metric="home-risks">0</strong>
      </div>
      <div class="list compact-list" data-home-risk-list></div>
    </div>
  </section>

  <section class="grid cols-2" style="margin-top: 16px;">
    <div class="panel">
      <div class="list-row">
        <h2><Building2 size={18} aria-hidden="true" /> 直近の会議室予約</h2>
        <a class="button secondary" href={`${base}rooms/`}>予約を見る</a>
      </div>
      <div class="list" data-home-bookings></div>
    </div>

    <div class="panel">
      <div class="list-row">
        <h2><Bell size={18} aria-hidden="true" /> 最新通知・課題</h2>
        <a class="button secondary" href={`${base}notices/`}>通知を見る</a>
      </div>
      <div class="list" data-home-notices></div>
    </div>
  </section>

  <section class="panel" style="margin-top: 16px;">
    <div class="list-row">
      <h2><CalendarDays size={18} aria-hidden="true" /> 今後の年間行事</h2>
      <a class="button secondary" href={`${base}events/`}>行事を見る</a>
    </div>
    <div class="list" data-home-events></div>
  </section>

  <section class="panel" style="margin-top: 16px;">
    <h2><ClipboardList size={18} aria-hidden="true" /> v2 / v3 運用</h2>
    <p class="meta">管理文書の版管理、承認フロー、電子印影を管理文書画面で扱えます。</p>
  </section>
</AppLayout>
