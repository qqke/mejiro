---
import AppLayout from "../layouts/AppLayout.astro";
import { FileSignature, Plus, Search, Store } from "@lucide/astro";
---

<AppLayout title="業者契約" page="vendors">
  <header class="page-head">
    <div>
      <p class="eyebrow">Vendors</p>
      <h1>業者契約</h1>
      <p class="lead">管理会社、清掃会社、点検業者、工事業者との連絡先と契約期間を一元管理します。</p>
    </div>
    <div class="page-actions">
      <button class="button" type="button" data-reveal-target="[data-vendor-form]">
        <Plus size={16} aria-hidden="true" />業者を登録
      </button>
      <button class="button secondary" type="button" data-reveal-target="[data-contract-form]">
        <FileSignature size={16} aria-hidden="true" />契約を登録
      </button>
    </div>
  </header>

  <section class="grid cols-3" aria-label="業者指標">
    <div class="panel metric">
      <span>登録業者</span>
      <strong data-metric="vendor-total">0</strong>
    </div>
    <div class="panel metric">
      <span>有効契約</span>
      <strong data-metric="contract-active">0</strong>
    </div>
    <div class="panel metric">
      <span>更新注意</span>
      <strong data-metric="contract-renewal">0</strong>
    </div>
  </section>

  <section class="grid cols-2" style="margin-top: 16px;">
    <form class="panel grid hidden" data-vendor-form>
      <h2><Plus size={18} aria-hidden="true" /> 業者を登録</h2>
      <div class="field">
        <label for="vendor-name">業者名</label>
        <input class="input" id="vendor-name" name="name" required />
      </div>
      <div class="form-grid">
        <div class="field">
          <label for="vendor-category">分類</label>
          <input class="input" id="vendor-category" name="category" placeholder="清掃、点検、工事など" required />
        </div>
        <div class="field">
          <label for="vendor-contact">担当者</label>
          <input class="input" id="vendor-contact" name="contact_name" />
        </div>
      </div>
      <div class="form-grid">
        <div class="field">
          <label for="vendor-phone">電話</label>
          <input class="input" id="vendor-phone" name="phone" />
        </div>
        <div class="field">
          <label for="vendor-email">メール</label>
          <input class="input" id="vendor-email" name="email" type="email" />
        </div>
      </div>
      <div class="field">
        <label for="vendor-note">備考</label>
        <textarea class="textarea" id="vendor-note" name="note"></textarea>
      </div>
      <button class="button" type="submit">登録する</button>
      <p class="status" data-vendor-status></p>
    </form>

    <div class="panel">
      <h2><Store size={18} aria-hidden="true" /> 業者一覧</h2>
      <label class="field list-search">
        <span><Search size={14} aria-hidden="true" /> 業者を検索</span>
        <input class="input" type="search" placeholder="業者名・分類・担当・連絡先" data-vendor-search />
      </label>
      <div class="list" data-vendor-list></div>
    </div>
  </section>

  <section class="grid cols-2" style="margin-top: 16px;">
    <form class="panel grid hidden" data-contract-form>
      <h2><FileSignature size={18} aria-hidden="true" /> 契約を登録</h2>
      <div class="field">
        <label for="contract-vendor">業者</label>
        <select class="select" id="contract-vendor" name="vendor_id" required data-contract-vendor-select></select>
      </div>
      <div class="field">
        <label for="contract-title">契約名</label>
        <input class="input" id="contract-title" name="title" required />
      </div>
      <div class="form-grid">
        <div class="field">
          <label for="contract-start">開始日</label>
          <input class="input" id="contract-start" name="start_date" type="date" required />
        </div>
        <div class="field">
          <label for="contract-end">終了日</label>
          <input class="input" id="contract-end" name="end_date" type="date" required />
        </div>
      </div>
      <div class="field">
        <label for="contract-amount">契約金額</label>
        <input class="input" id="contract-amount" name="amount" type="number" min="0" step="1" />
      </div>
      <button class="button" type="submit">契約を保存</button>
      <p class="status" data-contract-status></p>
    </form>

    <div class="panel">
      <h2><FileSignature size={18} aria-hidden="true" /> 契約一覧</h2>
      <label class="field list-search">
        <span><Search size={14} aria-hidden="true" /> 契約を検索</span>
        <input class="input" type="search" placeholder="契約名・業者・状態" data-contract-search />
      </label>
      <div class="list" data-contract-list></div>
    </div>
  </section>
</AppLayout>
