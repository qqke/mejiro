---
import AppLayout from "../layouts/AppLayout.astro";
import { Plus, Vote } from "@lucide/astro";
---

<AppLayout title="意見収集" page="surveys">
  <header class="page-head">
    <div>
      <p class="eyebrow">Surveys</p>
      <h1>意見収集</h1>
      <p class="lead">総会議案、修繕方針、行事日程などについて住民の意見を集めます。</p>
    </div>
    <div class="page-actions">
      <button class="button" type="button" data-reveal-target="[data-survey-form]">
        <Plus size={16} aria-hidden="true" />意見募集を作成
      </button>
    </div>
  </header>

  <section class="grid cols-3" aria-label="意見収集指標">
    <div class="panel metric">
      <span>受付中</span>
      <strong data-metric="survey-open">0</strong>
    </div>
    <div class="panel metric">
      <span>回答済み</span>
      <strong data-metric="survey-answered">0</strong>
    </div>
    <div class="panel metric">
      <span>締切済み</span>
      <strong data-metric="survey-closed">0</strong>
    </div>
  </section>

  <section class="grid cols-2" style="margin-top: 16px;">
    <form class="panel grid hidden" data-survey-form>
      <h2><Plus size={18} aria-hidden="true" /> 意見募集を作成</h2>
      <div class="field">
        <label for="survey-title">件名</label>
        <input class="input" id="survey-title" name="title" required />
      </div>
      <div class="field">
        <label for="survey-question">質問</label>
        <textarea class="textarea" id="survey-question" name="question" required></textarea>
      </div>
      <div class="field">
        <label for="survey-options">選択肢</label>
        <input class="input" id="survey-options" name="options" placeholder="賛成,反対,保留" required />
      </div>
      <div class="field">
        <label for="survey-closes-at">締切</label>
        <input class="input" id="survey-closes-at" name="closes_at" type="datetime-local" />
      </div>
      <button class="button" type="submit">作成する</button>
      <p class="status" data-survey-status></p>
    </form>

    <div class="panel">
      <h2><Vote size={18} aria-hidden="true" /> 意見募集一覧</h2>
      <div class="list" data-survey-list></div>
    </div>
  </section>
</AppLayout>
