---
import AppLayout from "../layouts/AppLayout.astro";
import { CheckCircle2, Newspaper, Plus } from "@lucide/astro";
---

<AppLayout title="回覧配布" page="circulars">
  <header class="page-head">
    <div>
      <p class="eyebrow">Circulars</p>
      <h1>回覧・配布物</h1>
      <p class="lead">回覧板、配布資料、規約改定案、行事案内の対象者と確認状況をまとめて管理します。</p>
    </div>
  </header>

  <section class="grid cols-3" aria-label="回覧配布指標">
    <div class="panel metric">
      <span>公開中</span>
      <strong data-metric="circular-published">0</strong>
    </div>
    <div class="panel metric">
      <span>未確認</span>
      <strong data-metric="circular-unread">0</strong>
    </div>
    <div class="panel metric">
      <span>期限近い</span>
      <strong data-metric="circular-due">0</strong>
    </div>
  </section>

  <section class="grid cols-2" style="margin-top: 16px;">
    <form class="panel grid hidden" data-circular-form>
      <h2><Plus size={18} aria-hidden="true" /> 回覧を作成</h2>
      <div class="field">
        <label for="circular-title">件名</label>
        <input class="input" id="circular-title" name="title" required />
      </div>
      <div class="form-grid">
        <div class="field">
          <label for="circular-kind">種別</label>
          <select class="select" id="circular-kind" name="kind">
            <option value="notice">お知らせ</option>
            <option value="minutes">議事録</option>
            <option value="event">行事</option>
            <option value="rule">規約</option>
            <option value="other">その他</option>
          </select>
        </div>
        <div class="field">
          <label for="circular-target">対象</label>
          <select class="select" id="circular-target" name="target_role">
            <option value="all">全員</option>
            <option value="resident">居民</option>
            <option value="board_member">理事</option>
            <option value="admin">管理者</option>
          </select>
        </div>
      </div>
      <div class="field">
        <label for="circular-due-date">確認期限</label>
        <input class="input" id="circular-due-date" name="due_date" type="date" />
      </div>
      <div class="field">
        <label for="circular-body">内容</label>
        <textarea class="textarea" id="circular-body" name="body" required></textarea>
      </div>
      <button class="button" type="submit">公開する</button>
      <p class="status" data-circular-status></p>
    </form>

    <div class="panel">
      <h2><Newspaper size={18} aria-hidden="true" /> 回覧一覧</h2>
      <div class="list" data-circular-list></div>
    </div>
  </section>

  <section class="panel" style="margin-top: 16px;">
    <h2><CheckCircle2 size={18} aria-hidden="true" /> 自分の確認履歴</h2>
    <div class="list compact-list" data-circular-ack-list></div>
  </section>
</AppLayout>
