---
import AppLayout from "../layouts/AppLayout.astro";
import { Building2, History, Users } from "@lucide/astro";
---

<AppLayout title="管理" page="admin">
  <header class="page-head">
    <div>
      <p class="eyebrow">Admin</p>
      <h1>管理</h1>
      <p class="lead">会議室、ユーザー権限、予約状況を管理します。必要な設定はこの画面から順に確認できます。</p>
    </div>
  </header>

  <section class="grid cols-2">
    <form class="panel grid" data-room-form>
      <h2><Building2 size={18} aria-hidden="true" /> 会議室を追加</h2>
      <div class="field">
        <label for="room-name">会議室名</label>
        <input class="input" id="room-name" name="name" required />
      </div>
      <div class="field">
        <label for="room-capacity">定員</label>
        <input class="input" id="room-capacity" name="capacity" type="number" min="1" value="10" />
      </div>
      <div class="field">
        <label for="room-notes">備考</label>
        <textarea class="textarea" id="room-notes" name="notes"></textarea>
      </div>
      <button class="button" type="submit">追加する</button>
      <p class="status" data-room-status></p>
    </form>

    <div class="panel">
      <h2>会議室一覧</h2>
      <div class="list" data-room-list></div>
    </div>
  </section>

  <section class="panel" style="margin-top: 16px;">
    <h2><Users size={18} aria-hidden="true" /> ユーザー権限</h2>
    <div class="list" data-profile-list></div>
  </section>

  <section class="panel" style="margin-top: 16px;">
    <h2><History size={18} aria-hidden="true" /> 操作履歴</h2>
    <div class="activity-log-tools">
      <label class="field">
        <span>キーワード</span>
        <input class="input" type="search" placeholder="内容・対象・担当者" data-activity-log-search />
      </label>
      <label class="field">
        <span>操作</span>
        <select class="select" data-activity-log-action>
          <option value="all">すべて</option>
          <option value="created">作成・登録</option>
          <option value="approval">承認</option>
          <option value="rejection">却下・差戻し</option>
          <option value="completion">完了・返却</option>
          <option value="closure">終了・中止</option>
          <option value="archived">保管</option>
        </select>
      </label>
      <p class="meta" data-activity-log-summary></p>
    </div>
    <div class="list compact-list" data-activity-log-list></div>
  </section>
</AppLayout>
