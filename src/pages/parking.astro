---
import AppLayout from "../layouts/AppLayout.astro";
import { Car, CircleParking, Plus, Search } from "@lucide/astro";
---

<AppLayout title="駐車場" page="parking">
  <header class="page-head">
    <div>
      <p class="eyebrow">Parking</p>
      <h1>駐車場</h1>
      <p class="lead">駐車区画と利用申請、承認状況を管理します。</p>
    </div>
    <div class="page-actions">
      <button class="button" type="button" data-reveal-target="[data-parking-space-form]">
        <Plus size={16} aria-hidden="true" />区画を登録
      </button>
    </div>
  </header>

  <section class="grid cols-3" aria-label="駐車場指標">
    <div class="panel metric">
      <span>空き区画</span>
      <strong data-metric="parking-available">0</strong>
    </div>
    <div class="panel metric">
      <span>利用中</span>
      <strong data-metric="parking-active">0</strong>
    </div>
    <div class="panel metric">
      <span>申請中</span>
      <strong data-metric="parking-pending">0</strong>
    </div>
  </section>

  <section class="grid cols-2" style="margin-top: 16px;">
    <form class="panel grid hidden" data-parking-space-form>
      <h2><Plus size={18} aria-hidden="true" /> 区画を登録</h2>
      <div class="form-grid">
        <div class="field">
          <label for="parking-code">区画番号</label>
          <input class="input" id="parking-code" name="code" required />
        </div>
        <div class="field">
          <label for="parking-assignment">配分方法</label>
          <select class="select" id="parking-assignment" name="assignment_method">
            <option value="first_come">先着</option>
            <option value="lottery">抽選</option>
          </select>
        </div>
      </div>
      <div class="form-grid">
        <div class="field">
          <label for="parking-location">場所</label>
          <input class="input" id="parking-location" name="location" />
        </div>
        <div class="field">
          <label for="parking-fee">月額</label>
          <input class="input" id="parking-fee" name="monthly_fee" type="number" min="0" step="1" />
        </div>
      </div>
      <button class="button" type="submit">登録する</button>
      <p class="status" data-parking-space-status></p>
    </form>

    <form class="panel grid" data-parking-permit-form>
      <h2><CircleParking size={18} aria-hidden="true" /> 利用申請</h2>
      <div class="field">
        <label for="parking-space">区画</label>
        <select class="select" id="parking-space" name="space_id" required data-parking-space-select></select>
      </div>
      <div class="field">
        <label for="parking-vehicle">車両情報</label>
        <input class="input" id="parking-vehicle" name="vehicle_label" placeholder="車番など" required />
      </div>
      <div class="field">
        <label for="parking-priority">優先区分</label>
        <select class="select" id="parking-priority" name="priority">
          <option value="primary">1台目</option>
          <option value="secondary">2台目</option>
        </select>
      </div>
      <div class="form-grid">
        <div class="field">
          <label for="parking-start">利用開始</label>
          <input class="input" id="parking-start" name="start_date" type="date" required />
        </div>
        <div class="field">
          <label for="parking-end">利用終了</label>
          <input class="input" id="parking-end" name="end_date" type="date" />
        </div>
      </div>
      <button class="button" type="submit">申請する</button>
      <p class="status" data-parking-permit-status></p>
    </form>

    <form class="panel grid" data-parking-procedure-form>
      <h2><CircleParking size={18} aria-hidden="true" /> 駐車手続き</h2>
      <div class="field">
        <label for="parking-procedure-permit">利用中の許可</label>
        <select class="select" id="parking-procedure-permit" name="permit_id" required data-parking-procedure-permit-select></select>
      </div>
      <div class="field">
        <label for="parking-procedure-kind">手続き</label>
        <select class="select" id="parking-procedure-kind" name="kind">
          <option value="vehicle_change">車両変更</option>
          <option value="return_notice">返還届</option>
          <option value="certificate">車庫証明</option>
        </select>
      </div>
      <div class="form-grid">
        <div class="field">
          <label for="parking-procedure-vehicle">変更後車両</label>
          <input class="input" id="parking-procedure-vehicle" name="requested_vehicle_label" placeholder="車両変更時のみ" />
        </div>
        <div class="field">
          <label for="parking-procedure-return">返還日</label>
          <input class="input" id="parking-procedure-return" name="requested_return_date" type="date" />
        </div>
      </div>
      <div class="field">
        <label for="parking-procedure-note">備考</label>
        <input class="input" id="parking-procedure-note" name="note" />
      </div>
      <button class="button" type="submit">手続きを申請する</button>
      <p class="status" data-parking-procedure-status></p>
    </form>
  </section>

  <section class="panel parking-layout-panel" aria-label="駐車場站位図" style="margin-top: 16px;">
    <div class="list-row">
      <div>
        <h2><Car size={18} aria-hidden="true" /> 駐車区画図</h2>
        <p class="meta">区画ごとの空き、利用中、申請中を確認できます。</p>
      </div>
      <div class="parking-layout-legend" aria-label="凡例">
        <span><i class="parking-legend-dot available"></i>空き</span>
        <span><i class="parking-legend-dot active"></i>利用中</span>
        <span><i class="parking-legend-dot pending"></i>申請中</span>
        <span><i class="parking-legend-dot inactive"></i>停止中</span>
      </div>
    </div>
    <div class="parking-layout" data-parking-layout></div>
  </section>

  <section class="grid cols-2" style="margin-top: 16px;">
    <div class="panel">
      <h2><Car size={18} aria-hidden="true" /> 区画一覧</h2>
      <label class="field list-search">
        <span><Search size={14} aria-hidden="true" /> 区画を検索</span>
        <input class="input" type="search" placeholder="区画番号・場所" data-parking-space-search />
      </label>
      <div class="list" data-parking-space-list></div>
    </div>
    <div class="panel">
      <h2><CircleParking size={18} aria-hidden="true" /> 利用申請一覧</h2>
      <label class="field list-search">
        <span><Search size={14} aria-hidden="true" /> 申請を検索</span>
        <input class="input" type="search" placeholder="車両情報・区画番号" data-parking-permit-search />
      </label>
      <div class="list" data-parking-permit-list></div>
    </div>
    <div class="panel">
      <h2><CircleParking size={18} aria-hidden="true" /> 駐車手続き一覧</h2>
      <div class="list" data-parking-procedure-list></div>
    </div>
  </section>
</AppLayout>
