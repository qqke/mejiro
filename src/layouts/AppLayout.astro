---
import "../styles/global.css";
import {
  Bell,
  Boxes,
  Building2,
  CalendarDays,
  CircleParking,
  ClipboardList,
  ClipboardCheck,
  FileText,
  HandCoins,
  Home,
  LogOut,
  MessageSquareWarning,
  KeyRound,
  Newspaper,
  NotebookTabs,
  Recycle,
  Settings,
  ShieldCheck,
  Store,
  Vote,
  Wrench,
} from "@lucide/astro";

type Props = {
  title: string;
  description?: string;
  page:
    | "home"
    | "rooms"
    | "notices"
    | "events"
    | "documents"
    | "maintenance"
    | "finance"
    | "assets"
    | "vendors"
    | "residents"
    | "surveys"
    | "safety"
    | "tasks"
    | "parking"
    | "requests"
    | "circulars"
    | "lending"
    | "duties"
    | "waste"
    | "meetings"
    | "inspections"
    | "admin";
};

const { title, description = "団地管理組合電子化システム", page } = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\//, "")}`;

const navItems = [
  { href: asset("/"), label: "ホーム", page: "home", icon: Home },
  { href: asset("/rooms/"), label: "会議室", page: "rooms", icon: Building2 },
  { href: asset("/notices/"), label: "通知・課題", page: "notices", icon: Bell },
  { href: asset("/events/"), label: "年間行事", page: "events", icon: CalendarDays },
  { href: asset("/documents/"), label: "管理文書", page: "documents", icon: FileText },
  { href: asset("/maintenance/"), label: "修繕工事", page: "maintenance", icon: Wrench },
  { href: asset("/finance/"), label: "収支台帳", page: "finance", icon: HandCoins },
  { href: asset("/assets/"), label: "資産台帳", page: "assets", icon: Boxes },
  { href: asset("/vendors/"), label: "業者契約", page: "vendors", icon: Store },
  { href: asset("/residents/"), label: "住民名簿", page: "residents", icon: NotebookTabs },
  { href: asset("/surveys/"), label: "意見収集", page: "surveys", icon: Vote },
  { href: asset("/safety/"), label: "防災安否", page: "safety", icon: ShieldCheck },
  { href: asset("/tasks/"), label: "理事タスク", page: "tasks", icon: ClipboardCheck },
  { href: asset("/parking/"), label: "駐車駐輪", page: "parking", icon: CircleParking },
  { href: asset("/requests/"), label: "相談苦情", page: "requests", icon: MessageSquareWarning },
  { href: asset("/circulars/"), label: "回覧配布", page: "circulars", icon: Newspaper },
  { href: asset("/lending/"), label: "鍵貸出", page: "lending", icon: KeyRound },
  { href: asset("/duties/"), label: "当番巡回", page: "duties", icon: ClipboardList },
  { href: asset("/waste/"), label: "ごみ資源", page: "waste", icon: Recycle },
  { href: asset("/meetings/"), label: "会議治理", page: "meetings", icon: Vote },
  { href: asset("/inspections/"), label: "長期点検", page: "inspections", icon: ClipboardCheck },
  { href: asset("/admin/"), label: "管理", page: "admin", icon: Settings },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={asset("/favicon.svg")} />
    <link rel="icon" href={asset("/favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | 団地管理組合</title>
  </head>
  <body data-page={page}>
    <div class="app-shell">
      <aside class="sidebar">
        <a class="brand" href={asset("/")} aria-label="ホーム">
          <span class="brand-mark">団</span>
          <span>
            <span class="brand-title">団地管理組合</span>
            <span class="brand-subtitle">予約・通知・年間行事</span>
          </span>
        </a>

        <nav class="nav" aria-label="主要ナビゲーション">
          {
            navItems.map((item) => {
              const Icon = item.icon;
              return (
                <a
                  class="nav-link"
                  href={item.href}
                  aria-current={item.page === page ? "page" : undefined}
                >
                  <Icon size={18} aria-hidden="true" />
                  <span>{item.label}</span>
                </a>
              );
            })
          }
        </nav>

        <div class="sidebar-footer">
          <div class="user-chip">
            <strong data-user-name>読み込み中</strong>
            <span data-user-role>ログイン確認中</span>
          </div>
          <button class="button secondary" type="button" data-action="sign-out">
            <LogOut size={16} aria-hidden="true" />
            ログアウト
          </button>
        </div>
      </aside>

      <main class="main">
        <slot />
      </main>
    </div>

    <script>
      import "../scripts/app.ts";
    </script>
  </body>
</html>
